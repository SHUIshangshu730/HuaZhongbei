\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces 双图像兼容性相图。横轴为纸面图案复杂度，纵轴为镜面图案复杂度；点形区分 High/Mixed/Low overlap 三类，颜色条给出具体兼容性评分 $C$。相图显示较高重叠组合主要沿复杂度相近区域分布，说明复杂度匹配比单独追求低复杂度更重要。\relax }}{18}{figure.caption.13}\protected@file@percent }
\newlabel{fig:q3phase}{{9}{18}{双图像兼容性相图。横轴为纸面图案复杂度，纵轴为镜面图案复杂度；点形区分 High/Mixed/Low overlap 三类，颜色条给出具体兼容性评分 $C$。相图显示较高重叠组合主要沿复杂度相近区域分布，说明复杂度匹配比单独追求低复杂度更重要。\relax }{figure.caption.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces 双图像兼容性热力图。行表示纸面图案类型，列表示镜面图案类型，颜色深浅表示兼容性评分 $C$。对角线高亮显示自兼容优势，箭头标识行/列的普遍低兼容性验证了方向敏感型图案的结构局限。\relax }}{19}{figure.caption.14}\protected@file@percent }
\newlabel{fig:q3heatmap}{{10}{19}{双图像兼容性热力图。行表示纸面图案类型，列表示镜面图案类型，颜色深浅表示兼容性评分 $C$。对角线高亮显示自兼容优势，箭头标识行/列的普遍低兼容性验证了方向敏感型图案的结构局限。\relax }{figure.caption.14}{}}
