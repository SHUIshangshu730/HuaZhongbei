\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces 镜面图像未指定时的双有意义设计实证。四列分别展示花卉纹样、罗盘徽记、鱼形轮廓和箭头标识四类图案的纸面原图（上排）与镜面反射结果（下排）。前三类图案在镜面中保持可辨识的结构特征，而箭头标识因方向语义在柱面反射中发生扭曲，成为本情形的边界案例。\relax }}{13}{figure.caption.10}\protected@file@percent }
\newlabel{fig:q2free}{{6}{13}{镜面图像未指定时的双有意义设计实证。四列分别展示花卉纹样、罗盘徽记、鱼形轮廓和箭头标识四类图案的纸面原图（上排）与镜面反射结果（下排）。前三类图案在镜面中保持可辨识的结构特征，而箭头标识因方向语义在柱面反射中发生扭曲，成为本情形的边界案例。\relax }{figure.caption.10}{}}
